# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ==================== 服务配置 ====================
# HTTP 服务端口
COACH_PORT=3000

# 管理员 QQ ID（逗号分隔多个）
# 获取方式：启动后查看日志中的 qqId 字段
COACH_ADMIN_QQ_IDS=your_qq_openid_here

# 数据存储目录
COACH_DATA_DIR=./data

# ==================== OpenClaw 配置 ====================
OPENCLAW_HOME=/root/.openclaw
OPENCLAW_WORKSPACE=/root/.openclaw/workspace

# ==================== QQ Bot 配置（可选） ====================
# 如果使用 QQ Bot 官方 API
QQ_BOT_APP_ID=your_app_id
QQ_BOT_TOKEN=your_token
QQ_BOT_SECRET=your_secret

# ==================== AI API 配置（可选） ====================
# 用于 AI 智能讲解功能
OPENAI_API_KEY=your_openai_key
OPENAI_BASE_URL=https://api.openai.com/v1

# ==================== 数据库配置（可选） ====================
# 默认使用 SQLite
DATABASE_URL=sqlite:./data/learning_coach.db

# ==================== 激活码配置 ====================
# 激活码前缀
ACTIVATION_CODE_PREFIX=XH2025

# ==================== 日志配置 ====================
LOG_LEVEL=info

# ==================== 开发配置 ====================
NODE_ENV=production