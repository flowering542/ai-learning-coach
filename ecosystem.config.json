{
  "apps": [
    {
      "name": "ai-learning-coach",
      "script": "./server.js",
      "instances": 1,
      "exec_mode": "fork",
      "env": {
        "NODE_ENV": "production",
        "COACH_PORT": 3000,
        "COACH_DATA_DIR": "./data",
        "COACH_ADMIN_QQ_IDS": "0868C7A469194C24FDF03912C5313735"
      },
      "env_production": {
        "NODE_ENV": "production"
      },
      "log_file": "./logs/combined.log",
      "out_file": "./logs/out.log",
      "error_file": "./logs/error.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "merge_logs": true,
      "max_memory_restart": "500M",
      "restart_delay": 3000,
      "max_restarts": 10,
      "min_uptime": "10s",
      "watch": false,
      "ignore_watch": ["node_modules", "logs", "data"],
      "autorestart": true,
      "kill_timeout": 5000,
      "listen_timeout": 10000
    }
  ]
}